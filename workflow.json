              "value": "={{ $fromAI('parameters3_Value', `ID da lista do Trello.\n\nValores permitidos:\n\nA fazer -> {ID_LISTA}\n\nEm andamento -> {ID_LISTA}\n\nConcluído -> {ID_LISTA}\n\nRetorne apenas um dos IDs acima.`, 'string') }}"
